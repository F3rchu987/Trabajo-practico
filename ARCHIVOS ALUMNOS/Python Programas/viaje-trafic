precio = float(input("Precio del litro: "))
personas = int(input("Cantidad de pasajeros: "))
consumo = float(input("Consumo (litros por km): "))
km = float(input("Distancia (km): "))
ganancia = float(input("Porcentaje de ganancia: "))

gastoNafta = (km * consumo) * precio
totalConGanancia = gastoNafta + (gastoNafta * ganancia / 100)
pagoIndividual = totalConGanancia / personas

print("Gasto en combustible: " + str(gastoNafta))
print("Total con ganancia: " + str(totalConGanancia))
print("Cada pasajero paga: " + str(pagoIndividual))